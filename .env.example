# SignalToPost example environment.
# Copy to .env for local development. Never commit real secrets.

# Core
NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signaltopost?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signaltopost?schema=public
TIMEZONE=UTC

# OpenAI, required for normalization, draft generation, rewriting, scoring, and summaries.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Content profile, optional.
# Leave empty to use the built-in Zurich founder-operator / fractional CFO profile.
# Separate list items with new lines or semicolons when your host supports multiline env vars.
CONTENT_PROFILE_CONTEXT=
CONTENT_PROFILE_THEMES=
CONTENT_PROFILE_VOICE_RULES=
CONTENT_PROFILE_AVOID_RULES=
CONTENT_PROFILE_X_GUIDANCE=
CONTENT_PROFILE_LINKEDIN_GUIDANCE=

# Telegram, required for the primary workflow.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# GitHub, optional. GITHUB_REPOS accepts "repo-name" or "owner/repo-name".
# If any entry is only "repo-name", set GITHUB_USERNAME as the default owner.
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_REPOS=owner/example-repo
GITHUB_WEBHOOK_SECRET=
GITHUB_MAX_IDEAS_PER_DAY=3
GITHUB_MAX_IDEAS_PER_REPO_PER_DAY=2

# X direct posting, optional.
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# LinkedIn, optional. The app currently supports manual fallback without direct posting.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_ACCESS_TOKEN=

# Local automatic publishing loop, usually disabled.
ENABLE_LOCAL_SCHEDULER=false
LOCAL_PUBLISH_POLL_SECONDS=60

# Hosted route protection. Use long random values in production.
CRON_SECRET=replace-with-a-long-random-secret
DASHBOARD_SECRET=replace-with-a-long-random-dashboard-password
