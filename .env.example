# Core
NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signaltopost?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signaltopost?schema=public
TIMEZONE=Europe/Zurich

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# GitHub
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_REPOS=remotejobs-ch
GITHUB_WEBHOOK_SECRET=

# X
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_ACCESS_TOKEN=

# Local automatic publishing loop
ENABLE_LOCAL_SCHEDULER=false
LOCAL_PUBLISH_POLL_SECONDS=60

# Cron protection for hosted scheduled jobs
CRON_SECRET=
